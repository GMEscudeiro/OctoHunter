  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  entries:
  - text: "No topo da sua tela h\xE1 uma barra que indica as armas que possui."
    displayImage: {fileID: 0}
    borderSprite: {fileID: 1139480493496450326, guid: 5f504932316d0bd2bada3acd4aed28e3, type: 3}
  - text: "A arma no primeiro slot segue seu mouse, as outras s\xE3o distribuidas
      ao redor do player."
    displayImage: {fileID: 0}
    borderSprite: {fileID: 1139480493496450326, guid: 5f504932316d0bd2bada3acd4aed28e3, type: 3}
  - text: "Voc\xEA pode trocar suas armas de tent\xE1culo."
    displayImage: {fileID: 0}
    borderSprite: {fileID: 1139480493496450326, guid: 5f504932316d0bd2bada3acd4aed28e3, type: 3}
  - text: "Voc\xEA pode clicar em uma arma para selecion\xE1-la."
    displayImage: {fileID: 0}
    borderSprite: {fileID: 1139480493496450326, guid: 5f504932316d0bd2bada3acd4aed28e3, type: 3}
  - text: E clicar em outra para trocar.
    displayImage: {fileID: 0}
    borderSprite: {fileID: 1139480493496450326, guid: 5f504932316d0bd2bada3acd4aed28e3, type: 3}
