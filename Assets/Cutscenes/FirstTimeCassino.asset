  m_Name: FirstTimeCassino
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  entries:
  - text: Seja bem vindo ao Grande Cassino Intergalatico!
    displayImage: {fileID: 6495231759997517424, guid: 6759ad9918e490216ab67f204bbfa9d4, type: 3}
    borderSprite: {fileID: 4473519594338958375, guid: 0541c5db625d5dbf5a9df53c9e9d9bc0, type: 3}
  - text: "Aqui voc\xEA pode usar suas moedas pra apostar por equipamentos novos"
    displayImage: {fileID: 7788860642955215874, guid: f2a6800d30ac85848b64dfd4882370ba, type: 3}
    borderSprite: {fileID: 4473519594338958375, guid: 0541c5db625d5dbf5a9df53c9e9d9bc0, type: 3}
  - text: "Como estamos sem tempo, vou deixar voc\xEA se acostumar com o lugar..."
    displayImage: {fileID: 7788860642955215874, guid: f2a6800d30ac85848b64dfd4882370ba, type: 3}
    borderSprite: {fileID: 4473519594338958375, guid: 0541c5db625d5dbf5a9df53c9e9d9bc0, type: 3}
